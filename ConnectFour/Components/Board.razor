@inject GameState State
@using System.Drawing

<div style="@CssVariables">
<nav>
   @for (byte i = 0; i < 7; i++)
   {
      var col = i;
      <span title="Click to play a piece" @onclick="() => PlayPiece(col)">🔽</span>
   }
</nav>
<div>
   <div class="board">
      @for (var i = 0; i < 42; i++)
      {
         <span class="container">
            <span></span>
         </span>
      }
   </div>
   @for (var i = 0; i < 42; i++)
   {
      <span class="@pieces[i]"></span>
   }
</div>
</div>
@code {
   [Parameter] public Color BoardColor { get; set; } = Color.Yellow;
   [Parameter] public Color Player1Color { get; set; } = Color.Red;
   [Parameter] public Color Player2Color { get; set; } = Color.Blue;

   private string CssVariables =>
      $"--board-bg: {ColorTranslator.ToHtml(BoardColor)}; --player1: {ColorTranslator.ToHtml(Player1Color)}; --player2: {ColorTranslator.ToHtml(Player2Color)};";

   private string[] pieces = new string[42];

   private void PlayPiece(byte col)
   {
      if (State.CheckForWin() != GameState.WinState.No_Winner)
      {
         return;
      }

      try
      {
         var player = State.PlayerTurn;
         var turn = State.CurrentTurn;
         var landingRow = State.PlayPiece(col);
         pieces[turn] = $"player{player} col{col} drop{landingRow}";
      }
      catch (ArgumentException)
      {
         // Column full or invalid move — ignore click
      }
   }

   protected override void OnInitialized()
   {
      State.ResetBoard();
   }
}